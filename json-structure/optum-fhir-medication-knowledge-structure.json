{
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/unitedhealth/refs/heads/main/json-structure/optum-fhir-medication-knowledge-structure.json",
  "name": "UnitedHealth Group FHIR MedicationKnowledge",
  "type": "object",
  "description": "FHIR R4 MedicationKnowledge resource for drug formulary coverage information from UnitedHealth Group",
  "fields": [
    {
      "name": "resourceType",
      "type": "string",
      "description": "FHIR resource type",
      "enum": [
        "MedicationKnowledge"
      ]
    },
    {
      "name": "id",
      "type": "string",
      "description": "Resource ID"
    },
    {
      "name": "status",
      "type": "string",
      "description": "Drug status",
      "enum": [
        "active",
        "inactive",
        "entered-in-error"
      ]
    },
    {
      "name": "code",
      "type": "object",
      "description": "Drug code (RxNorm)"
    },
    {
      "name": "synonym",
      "type": "array",
      "description": "Drug synonyms",
      "items": {
        "type": "string"
      }
    },
    {
      "name": "doseForm",
      "type": "object",
      "description": "Dose form coding"
    },
    {
      "name": "amount",
      "type": "object",
      "description": "Drug quantity"
    },
    {
      "name": "drugCharacteristic",
      "type": "array",
      "description": "Drug characteristics including formulary tier",
      "items": {
        "type": "object"
      }
    },
    {
      "name": "regulatory",
      "type": "array",
      "description": "Regulatory information",
      "items": {
        "type": "object"
      }
    }
  ]
}